@using AccountManager.Core.Enums
@using AccountManager.Core.Interfaces
@using AccountManager.Core.Models
@using AccountManager.Core.Services
@using Blazorise.Charts
@inject IAppState _state
@inject IAlertService _alertService
@inject ILeagueGraphService _leagueGraphService

@if (_accountListItem?.PageData?.Wins?.Chart is null)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_accountListItem?.PageData?.Wins?.Chart?.Data?.Any() is not true)
{
    <h5 class="no-data-label">No data available</h5>
}

<LineChart Class="@(_accountListItem?.PageData?.Wins?.Chart?.Data?.Any() is not true ? " d-none" : "")" @ref="lineChart" Options="lineChartOptions" TItem="CoordinatePair"></LineChart>

